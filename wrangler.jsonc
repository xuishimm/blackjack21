{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "twentyone",
  "pages_build_output_dir": "./public",
  "compatibility_date": "2026-06-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blackjack21-db",
      "database_id": "dbd8048c-0be5-4983-b43f-eaf2e7afc18b"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom",
        "script_name": "blackjack21"
      }
    ]
  }
}
